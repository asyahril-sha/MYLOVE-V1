-- =============================================================================
-- 9. TRIGGERS FOR CLEANUP
-- =============================================================================

-- Trigger: When PDKT ended, automatically create mantan
CREATE TRIGGER IF NOT EXISTS trg_pdkt_ended_to_mantan
AFTER UPDATE OF status ON pdkt_sessions
WHEN NEW.status = 'ended' AND OLD.status != 'ended'
BEGIN
    INSERT INTO mantan (
        id, user_id, pdkt_id, bot_name, role, status,
        putus_time, putus_reason, chemistry_history, milestones,
        total_chats, total_intim, total_climax,
        first_kiss_time, first_intim_time, become_pacar_time,
        last_chat_time
    ) VALUES (
        'MANTAN-' || NEW.bot_name || '-' || NEW.role || '-' || NEW.user_id || '-' || strftime('%s','now') || '-' || hex(randomblob(2)),
        NEW.user_id,
        NEW.id,
        NEW.bot_name,
        NEW.role,
        'putus',
        NEW.ended_at,
        COALESCE(NEW.end_reason, 'user_request'),
        '[]',
        NEW.milestones,
        NEW.total_chats,
        NEW.total_intim,
        NEW.total_climax,
        NULL,
        NULL,
        NULL,
        NEW.last_interaction
    );
END;

-- Trigger: When FWB accepted, update mantan status
CREATE TRIGGER IF NOT EXISTS trg_fwb_accepted_update_mantan
AFTER UPDATE OF status ON fwb_requests
WHEN NEW.status = 'accepted'
BEGIN
    UPDATE mantan SET 
        status = 'fwb_accepted',
        fwb_start_time = NEW.timestamp
    WHERE id = NEW.mantan_id;
END;

-- Trigger: When FWB ended, update mantan status
CREATE TRIGGER IF NOT EXISTS trg_fwb_ended_update_mantan
AFTER UPDATE OF status ON fwb_relations
WHEN NEW.status = 'ended'
BEGIN
    UPDATE mantan SET 
        status = 'fwb_ended',
        fwb_end_time = NEW.ended_at
    WHERE id = NEW.mantan_id;
END;


-- =============================================================================
-- 10. VIEWS FOR EASY QUERYING
-- =============================================================================

-- View: Active PDKT
CREATE VIEW IF NOT EXISTS v_active_pdkt AS
SELECT 
    p.*,
    u.username,
    u.first_name
FROM pdkt_sessions p
JOIN users u ON p.user_id = u.telegram_id
WHERE p.status IN ('active', 'paused');

-- View: Active FWB
CREATE VIEW IF NOT EXISTS v_active_fwb AS
SELECT 
    f.*,
    u.username,
    u.first_name,
    m.putus_time,
    m.putus_reason
FROM fwb_relations f
JOIN users u ON f.user_id = u.telegram_id
LEFT JOIN mantan m ON f.mantan_id = m.id
WHERE f.status IN ('active', 'paused');

-- View: Active HTS
CREATE VIEW IF NOT EXISTS v_active_hts AS
SELECT 
    h.*,
    u.username,
    u.first_name,
    (h.expiry_time - strftime('%s','now')) / 86400 as days_remaining
FROM hts_relations h
JOIN users u ON h.user_id = u.telegram_id
WHERE h.status = 'active' AND h.expiry_time > strftime('%s','now');

-- View: Mantan with FWB status
CREATE VIEW IF NOT EXISTS v_mantan_with_fwb AS
SELECT 
    m.*,
    CASE 
        WHEN f.id IS NOT NULL THEN 'active_fwb'
        WHEN fr.id IS NOT NULL AND fr.status = 'pending' THEN 'fwb_pending'
        WHEN fr.id IS NOT NULL AND fr.status = 'declined' THEN 'fwb_declined'
        ELSE 'no_fwb'
    END as fwb_status,
    f.status as fwb_relation_status,
    fr.status as fwb_request_status
FROM mantan m
LEFT JOIN fwb_relations f ON m.id = f.mantan_id AND f.status != 'ended'
LEFT JOIN fwb_requests fr ON m.id = fr.mantan_id AND fr.status = 'pending';


