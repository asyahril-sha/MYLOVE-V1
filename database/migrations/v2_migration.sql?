-- =============================================================================
-- 1. PDKT SESSIONS TABLE
-- =============================================================================
CREATE TABLE IF NOT EXISTS pdkt_sessions (
    id TEXT PRIMARY KEY,                          -- PDKT-SARI-IPAR-123-1647358291-ABC1
    user_id INTEGER NOT NULL,
    role TEXT NOT NULL,
    bot_name TEXT NOT NULL,
    status TEXT DEFAULT 'active',                  -- active, paused, ended
    direction TEXT NOT NULL,                       -- user_ke_bot, bot_ke_user, timbal_balik, bingung
    chemistry_score REAL DEFAULT 50.0,
    chemistry_level TEXT DEFAULT 'biasa',          -- dingin, biasa, hangat, cocok, sangat_cocok, soulmate
    mood TEXT DEFAULT 'calm',                       -- happy, sad, excited, dll
    level INTEGER DEFAULT 1,
    total_duration REAL DEFAULT 0.0,                -- dalam menit
    total_chats INTEGER DEFAULT 0,
    total_intim INTEGER DEFAULT 0,
    total_climax INTEGER DEFAULT 0,
    created_at REAL NOT NULL,
    last_interaction REAL NOT NULL,
    paused_at REAL,
    ended_at REAL,
    end_reason TEXT,
    inner_thoughts TEXT,                            -- JSON array
    milestones TEXT,                                -- JSON array
    metadata TEXT,                                  -- JSON object
    FOREIGN KEY (user_id) REFERENCES users (telegram_id)
);

CREATE INDEX IF NOT EXISTS idx_pdkt_sessions_user ON pdkt_sessions(user_id, status);
CREATE INDEX IF NOT EXISTS idx_pdkt_sessions_role ON pdkt_sessions(role);


-- =============================================================================
-- 2. PDKT INNER THOUGHTS TABLE
-- =============================================================================
CREATE TABLE IF NOT EXISTS pdkt_inner_thoughts (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    pdkt_id TEXT NOT NULL,
    thought TEXT NOT NULL,
    context TEXT,
    timestamp REAL NOT NULL,
    FOREIGN KEY (pdkt_id) REFERENCES pdkt_sessions (id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_inner_thoughts_pdkt ON pdkt_inner_thoughts(pdkt_id, timestamp);


-- =============================================================================
-- 3. MANTAN TABLE (dari PDKT yang putus)
-- =============================================================================
CREATE TABLE IF NOT EXISTS mantan (
    id TEXT PRIMARY KEY,                          -- MANTAN-SARI-IPAR-123-1647358291-ABC1
    user_id INTEGER NOT NULL,
    pdkt_id TEXT NOT NULL,
    bot_name TEXT NOT NULL,
    role TEXT NOT NULL,
    status TEXT DEFAULT 'putus',                   -- putus, fwb_requested, fwb_accepted, fwb_declined, fwb_ended
    putus_time REAL NOT NULL,
    putus_reason TEXT NOT NULL,
    chemistry_history TEXT,                        -- JSON array
    milestones TEXT,                               -- JSON array
    total_chats INTEGER DEFAULT 0,
    total_intim INTEGER DEFAULT 0,
    total_climax INTEGER DEFAULT 0,
    first_kiss_time REAL,
    first_intim_time REAL,
    become_pacar_time REAL,
    last_chat_time REAL NOT NULL,
    fwb_requests TEXT,                             -- JSON array of request IDs
    fwb_start_time REAL,
    fwb_end_time REAL,
    FOREIGN KEY (user_id) REFERENCES users (telegram_id),
    FOREIGN KEY (pdkt_id) REFERENCES pdkt_sessions (id)
);

CREATE INDEX IF NOT EXISTS idx_mantan_user ON mantan(user_id, status);
CREATE INDEX IF NOT EXISTS idx_mantan_pdkt ON mantan(pdkt_id);


-- =============================================================================
-- 4. FWB REQUESTS TABLE
-- =============================================================================
CREATE TABLE IF NOT EXISTS fwb_requests (
    id TEXT PRIMARY KEY,                          -- FWBREQ-123-1647358291-ABC1
    user_id INTEGER NOT NULL,
    mantan_id TEXT NOT NULL,
    bot_name TEXT NOT NULL,
    user_message TEXT,
    timestamp REAL NOT NULL,
    status TEXT NOT NULL,                          -- pending, accepted, declined, expired
    bot_decision TEXT,                             -- JSON object
    expiry_time REAL NOT NULL,
    FOREIGN KEY (user_id) REFERENCES users (telegram_id),
    FOREIGN KEY (mantan_id) REFERENCES mantan (id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_fwb_requests_user ON fwb_requests(user_id, status);
CREATE INDEX IF NOT EXISTS idx_fwb_requests_mantan ON fwb_requests(mantan_id);


-- =============================================================================
-- 5. FWB RELATIONS TABLE (hasil request yang diterima)
-- =============================================================================
CREATE TABLE IF NOT EXISTS fwb_relations (
    id TEXT PRIMARY KEY,                          -- FWB-SARI-IPAR-123-1647358291-ABC1
    user_id INTEGER NOT NULL,
    mantan_id TEXT NOT NULL,
    bot_name TEXT NOT NULL,
    role TEXT NOT NULL,
    status TEXT DEFAULT 'active',                  -- active, paused, ended
    created_at REAL NOT NULL,
    last_interaction REAL NOT NULL,
    chemistry_score REAL DEFAULT 50.0,
    climax_count INTEGER DEFAULT 0,
    intim_count INTEGER DEFAULT 0,
    total_chats INTEGER DEFAULT 0,
    pause_history TEXT,                            -- JSON array
    ended_at REAL,
    end_reason TEXT,
    FOREIGN KEY (user_id) REFERENCES users (telegram_id),
    FOREIGN KEY (mantan_id) REFERENCES mantan (id)
);

CREATE INDEX IF NOT EXISTS idx_fwb_user ON fwb_relations(user_id, status);
CREATE INDEX IF NOT EXISTS idx_fwb_mantan ON fwb_relations(mantan_id);


-- =============================================================================
-- 6. HTS RELATIONS TABLE (dari NON-PDKT)
-- =============================================================================
CREATE TABLE IF NOT EXISTS hts_relations (
    id TEXT PRIMARY KEY,                          -- HTS-SARI-IPAR-123-1647358291-ABC1
    user_id INTEGER NOT NULL,
    role TEXT NOT NULL,
    bot_name TEXT NOT NULL,
    status TEXT DEFAULT 'active',                  -- active, expired
    created_at REAL NOT NULL,
    expiry_time REAL NOT NULL,                      -- created_at + 90 days
    last_interaction REAL NOT NULL,
    chemistry_score REAL DEFAULT 50.0,
    climax_count INTEGER DEFAULT 0,
    intimacy_level INTEGER DEFAULT 7,
    total_chats INTEGER DEFAULT 0,
    total_intim INTEGER DEFAULT 0,
    history TEXT,                                   -- JSON array
    FOREIGN KEY (user_id) REFERENCES users (telegram_id)
);

CREATE INDEX IF NOT EXISTS idx_hts_user ON hts_relations(user_id, status);
CREATE INDEX IF NOT EXISTS idx_hts_expiry ON hts_relations(expiry_time);


-- =============================================================================
-- 7. MEMORIES V2 TABLE (untuk hippocampus system)
-- =============================================================================
CREATE TABLE IF NOT EXISTS memories_v2 (
    id TEXT PRIMARY KEY,                          -- MEM-123-1647358291-ABC1
    user_id INTEGER NOT NULL,
    session_id TEXT,
    content TEXT NOT NULL,
    memory_type TEXT NOT NULL,                      -- compact, episodic, semantic
    importance REAL DEFAULT 0.5,
    emotional_tag TEXT,
    timestamp REAL NOT NULL,
    access_count INTEGER DEFAULT 0,
    last_access REAL NOT NULL,
    context TEXT,                                   -- JSON object
    metadata TEXT,                                  -- JSON object
    FOREIGN KEY (user_id) REFERENCES users (telegram_id)
);

CREATE INDEX IF NOT EXISTS idx_memories_v2_user ON memories_v2(user_id, memory_type);
CREATE INDEX IF NOT EXISTS idx_memories_v2_access ON memories_v2(last_access);
CREATE INDEX IF NOT EXISTS idx_memories_v2_importance ON memories_v2(importance DESC);


