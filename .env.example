# =============================================================================
# MYLOVE ULTIMATE VERSI 1 - ENVIRONMENT VARIABLES
# =============================================================================

# ===== API KEYS =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_ID=6792300623

# ===== DATABASE =====
DB_TYPE=sqlite
DB_PATH=data/mylove.db

# ===== AI SETTINGS =====
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=500
AI_TIMEOUT=30
MIN_MESSAGE_LENGTH=1000
MAX_MESSAGE_LENGTH=2000
TARGET_RESPONSE_TIME=5

# ===== WEBHOOK =====
PORT=8080
WEBHOOK_URL=https://mylove-v1-production.up.railway.app/webhook
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BACKOFF=2
ENABLE_POLLING_FALLBACK=true

# ===== FEATURES =====
SEXUAL_CONTENT_ENABLED=true
PUBLIC_RISK_ENABLED=true
BOT_INITIATIVE_ENABLED=true
AFTERCARE_ENABLED=true

# ===== SESSION =====
SESSION_RETENTION_DAYS=30
SESSION_AUTO_DELETE=true

# ===== BACKUP =====
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION_DAYS=7

# ===== LOGGING =====
LOG_LEVEL=INFO
