# =============================================================================
# MYLOVE ULTIMATE VERSI 1 - ENVIRONMENT VARIABLES
# =============================================================================
# Copy file ini ke .env dan isi dengan credentials kamu
# cp .env.example .env

# ===== API KEYS =====
# Dapatkan dari platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Dapatkan dari @BotFather di Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ID Telegram kamu (untuk single user)
# Dapatkan dari @userinfobot di Telegram
ADMIN_ID=your_telegram_id_here

# ===== DATABASE =====
# SQLite untuk single user (ringan)
DB_TYPE=sqlite
DB_PATH=data/mylove.db

# ===== AI SETTINGS =====
# Temperatur: 0.0 - 1.0 (0.9 = kreatif, 0.7 = seimbang)
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=500
AI_TIMEOUT=30

# ===== WEBHOOK SETTINGS =====
# Untuk deployment di Railway
PORT=8080
RAILWAY_PUBLIC_DOMAIN=your-app.railway.app  # Diisi Railway otomatis

# Fallback jika webhook error
WEBHOOK_URL=https://your-domain.com  # Untuk custom domain
WEBHOOK_SECRET=your_secret_here  # Optional

# ===== FEATURE TOGGLES =====
# Sexual content (18+)
SEXUAL_CONTENT_ENABLED=true
PUBLIC_RISK_ENABLED=true
BOT_INITIATIVE_ENABLED=true
AFTERCARE_ENABLED=true

# ===== PERFORMANCE =====
# Response < 5 detik, 1000-2000 karakter
MAX_MESSAGE_LENGTH=2000
MIN_MESSAGE_LENGTH=1000
RESPONSE_TIMEOUT=5

# ===== BACKUP =====
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600  # detik (1 jam)
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=data/backups

# ===== SESSION =====
# Auto-delete setelah 30 hari
SESSION_RETENTION_DAYS=30
SESSION_DIR=data/sessions

# ===== MEMORY =====
# Vector DB untuk semantic memory
VECTOR_DB_DIR=data/vector_db
MEMORY_DIR=data/memory

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_DIR=data/logs

# ===== MONITORING (Optional) =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ===== SECURITY (Optional) =====
# Untuk enkripsi data sensitif
ENCRYPTION_KEY=your_encryption_key_here  # 32 byte base64
JWT_SECRET=your_jwt_secret_here
